# 이 파일을 복사해 .env로 저장하고 실제 값을 채우세요.
# .env는 절대 GitHub에 올리지 마세요 (이미 .gitignore에 포함됨).
# 프로덕션 접속 정보(진짜 DATABASE_URL 등)는 여기에도, .env에도 두지 말 것 —
# 오직 .env.production.local(gitignore 대상)에만 둡니다.

# ── 데이터베이스 (로컬 MySQL) ──
# 형식: mysql://사용자:비밀번호@호스트:포트/DB이름
# 프로덕션 DB명은 'test'임 (프로젝트명 'bungaego'와 혼동 주의 - 실제로 한 번 사고 났음)
DATABASE_URL=mysql://bungaego:changeme@localhost:3306/bungaego

# ── 세션 암호화 키 (아무 긴 랜덤 문자열) ──
JWT_SECRET=local-dev-secret-please-change-this-to-a-long-random-string-1234567890

# ── 로컬 개발 로그인 활성화 (/api/dev-login) ──
LOCAL_DEV_AUTH=true

# ── 아래는 로컬에서 실제로 쓰지 않지만, 코드가 읽으므로 더미값으로 채움 ──
VITE_APP_ID=local-dev-app
OAUTH_SERVER_URL=http://localhost:9999
OWNER_OPEN_ID=local-admin-openid
OWNER_NAME=로컬관리자
BUILT_IN_FORGE_API_URL=http://localhost:9999
BUILT_IN_FORGE_API_KEY=local-dev-key
VITE_OAUTH_PORTAL_URL=http://localhost:9999

# ── 카카오맵(JavaScript SDK) 앱 키 — Kakao Developers(developers.kakao.com)에서 발급 ──
# 내 애플리케이션 > 앱 키 > JavaScript 키. 플랫폼 설정에 사용 도메인 등록 필요.
VITE_KAKAO_MAP_APP_KEY=

# ── 카카오 로그인 — Kakao Developers > 제품 설정 > 카카오 로그인 활성화 필요 ──
# REST API 키(내 애플리케이션 > 앱 키), Redirect URI에
# https://<도메인>/api/oauth/kakao/callback 등록 필요.
KAKAO_REST_API_KEY=
# 선택: 카카오 로그인 보안 > Client Secret 활성화 시에만 설정
KAKAO_CLIENT_SECRET=

# ── 애널리틱스(선택, 빈 값이면 경고만 뜨고 무시됨) ──
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── 크로스 오리진 클라이언트(Capacitor 앱 등) 대비, 기본은 비활성 ──
# true일 때만 세션 쿠키가 SameSite=None; Secure로 발급됩니다.
CROSS_SITE_COOKIES=false

# ── 기능 플래그: 테마 트립(standard 외 테마) 생성/노출 여부 (기본 비활성) ──
FEATURE_THEMES=false
